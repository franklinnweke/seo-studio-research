{
  "$defs": {
    "ClaimAnnotation": {
      "additionalProperties": false,
      "properties": {
        "claim_id": {
          "minLength": 1,
          "title": "Claim Id",
          "type": "string"
        },
        "claim_text": {
          "minLength": 1,
          "title": "Claim Text",
          "type": "string"
        },
        "evidence_note": {
          "default": "",
          "title": "Evidence Note",
          "type": "string"
        },
        "label": {
          "enum": [
            "supported",
            "unsupported",
            "contradicted",
            "not_verifiable_from_permitted_evidence"
          ],
          "title": "Label",
          "type": "string"
        }
      },
      "required": [
        "claim_id",
        "claim_text",
        "label"
      ],
      "title": "ClaimAnnotation",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "blinded_condition_id": {
      "title": "Blinded Condition Id",
      "type": "string"
    },
    "brand_alignment_score": {
      "anyOf": [
        {
          "maximum": 5,
          "minimum": 1,
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Brand Alignment Score"
    },
    "calibration_item": {
      "default": false,
      "title": "Calibration Item",
      "type": "boolean"
    },
    "claims": {
      "items": {
        "$ref": "#/$defs/ClaimAnnotation"
      },
      "title": "Claims",
      "type": "array"
    },
    "concision_fluency_score": {
      "anyOf": [
        {
          "maximum": 5,
          "minimum": 1,
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Concision Fluency Score"
    },
    "contextual_usefulness_score": {
      "anyOf": [
        {
          "maximum": 5,
          "minimum": 1,
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Contextual Usefulness Score"
    },
    "disposition": {
      "enum": [
        "accept_unchanged",
        "minor_edit",
        "major_edit",
        "reject"
      ],
      "title": "Disposition",
      "type": "string"
    },
    "factual_grounding_score": {
      "anyOf": [
        {
          "maximum": 5,
          "minimum": 1,
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Factual Grounding Score"
    },
    "item_id": {
      "title": "Item Id",
      "type": "string"
    },
    "notes": {
      "default": "",
      "title": "Notes",
      "type": "string"
    },
    "purpose_appropriateness_score": {
      "anyOf": [
        {
          "maximum": 5,
          "minimum": 1,
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Purpose Appropriateness Score"
    },
    "record_type": {
      "default": "individual",
      "enum": [
        "individual",
        "adjudicated"
      ],
      "title": "Record Type",
      "type": "string"
    },
    "redundancy_control_score": {
      "anyOf": [
        {
          "maximum": 5,
          "minimum": 1,
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Redundancy Control Score"
    },
    "repeat": {
      "const": 1,
      "default": 1,
      "title": "Repeat",
      "type": "integer"
    },
    "review_item_id": {
      "title": "Review Item Id",
      "type": "string"
    },
    "reviewer_alias": {
      "title": "Reviewer Alias",
      "type": "string"
    },
    "rubric_version": {
      "default": "rubric-v1",
      "enum": [
        "rubric-v1",
        "rubric-v1.1"
      ],
      "title": "Rubric Version",
      "type": "string"
    },
    "safety_score": {
      "anyOf": [
        {
          "maximum": 5,
          "minimum": 1,
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Safety Score"
    },
    "salient_coverage_score": {
      "anyOf": [
        {
          "maximum": 5,
          "minimum": 1,
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Salient Coverage Score"
    }
  },
  "required": [
    "item_id",
    "review_item_id",
    "blinded_condition_id",
    "reviewer_alias",
    "disposition"
  ],
  "title": "AnnotationRecord",
  "type": "object"
}
