# OS and editor files
.DS_Store
.idea/
.vscode/
*.swp
*.swo

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Environment and local secrets
.env
.env.*
!.env.example
backend/.env
backend/.env.*
frontend/.env
frontend/.env.*
!backend/.env.example
!frontend/.env.example

# Python
backend/.venv/
backend/venv/
backend/.pytest_cache/
backend/.mypy_cache/
backend/.ruff_cache/
backend/.coverage
backend/htmlcov/
backend/**/__pycache__/
backend/**/*.py[cod]

# Backend local runtime storage
backend/app/storage/uploads/*
backend/app/storage/processed/*
backend/app/storage/exports/*
backend/app/storage/temp/*
!backend/app/storage/uploads/.gitkeep
!backend/app/storage/processed/.gitkeep
!backend/app/storage/exports/.gitkeep
!backend/app/storage/temp/.gitkeep

# Frontend dependencies and builds
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/build/
frontend/coverage/
frontend/.vercel/
frontend/*.tsbuildinfo

# Temporary files
/tmp/
/temp/
