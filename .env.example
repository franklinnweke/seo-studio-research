# Docker Compose reads this root file for variable substitution.
# Copy it to .env for local Compose use. Never commit the resulting .env.

SEO_STUDIO_FRONTEND_ORIGIN=http://localhost:11501
SEO_STUDIO_FRONTEND_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:11501,http://127.0.0.1:11501

SEO_STUDIO_AI_PROVIDER=ollama
SEO_STUDIO_OLLAMA_BASE_URL=http://host.docker.internal:11434
SEO_STUDIO_OLLAMA_MODEL=qwen3.5:9b
SEO_STUDIO_VISION_MODEL=qwen2.5vl:3b
SEO_STUDIO_LANGUAGE_MODEL=qwen3.5:9b
SEO_STUDIO_OLLAMA_TIMEOUT_SECONDS=600
SEO_STUDIO_AI_HEALTH_TIMEOUT_SECONDS=3
SEO_STUDIO_CONTEXT_METADATA_ENABLED=false
SEO_STUDIO_PURPOSE_SUGGESTION_ENABLED=false
SEO_STUDIO_RESEARCH_PROVENANCE_ENABLED=false
SEO_STUDIO_VISION_MODEL_DIGEST=
SEO_STUDIO_LANGUAGE_MODEL_DIGEST=
SEO_STUDIO_AI_LANGUAGE_TIMEOUT_SECONDS=120
SEO_STUDIO_AI_CROP_TIMEOUT_SECONDS=120
SEO_STUDIO_AI_PREVIEW_MAX_WIDTH=1024
