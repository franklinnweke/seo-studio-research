    "/api/jobs/{job_id}/process": {
      "post": {
        "description": "Processes every validated image in an image job using the provided compression, conversion, and filename cleanup settings. Defaults match the RFC: lossy mode, quality 80, no resize, metadata stripping enabled, and original output format. It can convert output format to WebP, JPG, PNG, or keep the original extension. Optional filename overrides are sanitized, lowercased, de-duplicated, and saved with the selected output extension. Processed files are written to `storage/processed/{job_id}/images`. Transparent images converted to JPG are flattened onto a white background.",
        "operationId": "process_image_job_api_jobs__job_id__process_post",
        "parameters": [
          {
            "in": "path",
            "name": "job_id",
            "required": true,
            "schema": {
              "title": "Job Id",
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ImageCompressionSettings",
                "description": "Processing settings. Quality is most relevant for JPEG and WebP; PNG uses lossless optimization behavior. filename_overrides may be used to manually set cleaned output filenames by uploaded file id."
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ImageCompressionResponse"
                }
              }
            },
            "description": "Successful Response"
          },
          "400": {
            "description": "The job has no images or settings are invalid."
          },
          "404": {
            "description": "Job or uploaded source file not found."
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Process uploaded image files",
        "tags": [
          "image jobs"
        ]
      }
    },
